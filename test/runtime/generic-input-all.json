      "type": "boolean",
      "description": "Status if marriage live in given house"
    },
    "union_type": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        }
      ]
    },
    "array_type": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          }
        ]
      }
    },
    "tuple_type": {
      "type": "array",
      "items": [
        {
          "type": "string"
        },
        {
          "type": "number"
