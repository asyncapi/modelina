        <xs:element name=\\"status\\">
          <xs:simpleType>
            <xs:restriction base=\\"xs:string\\">
              <xs:enumeration value=\\"active\\"/>
              <xs:enumeration value=\\"inactive\\"/>
              <xs:enumeration value=\\"pending\\"/>
            </xs:restriction>
          </xs:simpleType>
        </xs:element>
